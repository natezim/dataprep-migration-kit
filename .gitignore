# Secrets — never commit
.env
*.token

# Raw Dataprep exports (real business logic) — keep ALL of context/ out of git.
# These are exported recipes; they don't belong in source control.
/context/*
!/context/.gitkeep

# Work products — data exports and scratch only.
# (output/parity/ and output/backlog.md ARE committed — they're the evidence trail.)
output/data/
output/temp/

# OS / editor cruft
.DS_Store
Thumbs.db
