# Dataprep / Trifacta Classic REST API — copy this file to `.env` and fill in.
# `.env` is gitignored and is NEVER read by Gemini (it reads this .example only).

# Your workspace API host. Find it from the URL when you're logged into Dataprep.
#   Google Cloud Dataprep:        https://api.clouddataprep.com
#   Alteryx Analytics Cloud (us): https://api.us1.alteryxcloud.com
#   Self-managed:                 https://<your-host>:<port>
DATAPREP_API_BASE_URL=https://api.clouddataprep.com

# Personal Access Token (bearer). Generate in the UI:
#   User menu -> Preferences -> Access Tokens -> Generate New Token
# Paste it here in your local .env only. Never commit it.
DATAPREP_API_TOKEN=
